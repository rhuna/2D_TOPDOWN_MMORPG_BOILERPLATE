
# ----------------------------
# Build folders
# ----------------------------
build/
build-*/
out/
bin/
dist/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json
Testing/
_deps/

# ----------------------------
# CMake / generated files
# ----------------------------
*.cmake.user
Makefile
install_manifest.txt

# ----------------------------
# Binaries / libraries
# ----------------------------
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.obj
*.o
*.pdb
*.ilk
*.exp

# ----------------------------
# Logs / temp / cache
# ----------------------------
*.log
*.tmp
*.temp
.cache/
.cache-loader/
*.stackdump

# ----------------------------
# IDE/editor files
# ----------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ----------------------------
# OS junk
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------
# Python cache if any tools/scripts exist
# ----------------------------
__pycache__/
*.pyc
.venv/

# ----------------------------
# Large generated game content
# ----------------------------
*.zip
*.7z

# Keep source assets, but ignore exported/generated asset caches
assets/cache/
assets/generated/

# ----------------------------
# Optional: ignore local config overrides
# ----------------------------
.env
.env.local
local_settings.json